        "parameters": [
          {
            "name": "body",
            "description": "ApplyPolicyInput creates or replaces a policy (upsert by name).",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1alpha1ApplyPolicyInput"
            }
          }
        ],
        "tags": [
          "JitsudoService"
