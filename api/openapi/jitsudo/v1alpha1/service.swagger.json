    "/api/v1alpha1/requests": {
      "get": {
        "summary": "ListRequests returns a filtered list of elevation requests.",
        "operationId": "JitsudoService_ListRequests",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1alpha1ListRequestsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "mine",
            "description": "Filter to requests belonging to the caller.",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "pending",
            "description": "Filter to pending requests (for approvers).",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "requesterIdentity",
            "description": "Filter by requester identity.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "state",
            "description": "Filter by state.",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "REQUEST_STATE_UNSPECIFIED",
              "REQUEST_STATE_PENDING",
              "REQUEST_STATE_APPROVED",
              "REQUEST_STATE_REJECTED",
              "REQUEST_STATE_ACTIVE",
              "REQUEST_STATE_EXPIRED",
              "REQUEST_STATE_REVOKED"
            ],
            "default": "REQUEST_STATE_UNSPECIFIED"
          }
        ],
        "tags": [
          "JitsudoService"
        ]
      },
      "post": {
        "summary": "CreateRequest submits a new elevation request.",
        "operationId": "JitsudoService_CreateRequest",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1alpha1CreateRequestResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "CreateRequestInput is the body for submitting a new elevation request.",
