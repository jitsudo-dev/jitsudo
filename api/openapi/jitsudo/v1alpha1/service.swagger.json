        "requesterIdentity": {
          "type": "string",
          "description": "Identity of the requester (IdP subject claim, typically email)."
        },
        "provider": {
          "type": "string",
          "description": "Cloud provider (aws, azure, gcp, kubernetes)."
        },
        "role": {
          "type": "string",
          "description": "The role or permission set to grant."
        },
        "resourceScope": {
          "type": "string",
