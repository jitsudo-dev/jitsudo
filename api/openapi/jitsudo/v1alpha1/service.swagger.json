    "/api/v1alpha1/audit": {
      "get": {
        "summary": "QueryAudit queries the append-only audit log with optional filters.",
        "operationId": "JitsudoService_QueryAudit",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1alpha1QueryAuditResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "actorIdentity",
            "description": "Filter by actor identity.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "provider",
            "description": "Filter by provider.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "requestId",
            "description": "Filter by request ID.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "since",
            "description": "Return events after this timestamp.",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "until",
            "description": "Return events before this timestamp.",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "pageToken",
            "description": "Pagination token from a previous response.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "pageSize",
            "description": "Maximum number of events to return (default 100, max 1000).",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "JitsudoService"
        ]
      }
    },
