          "description": "Identity that last modified this policy."
        }
      },
      "description": "Policy represents a stored Rego policy."
    },
    "v1alpha1PolicyType": {
      "type": "string",
      "enum": [
        "POLICY_TYPE_UNSPECIFIED",
        "POLICY_TYPE_ELIGIBILITY",
        "POLICY_TYPE_APPROVAL"
      ],
      "default": "POLICY_TYPE_UNSPECIFIED",
      "description": "PolicyType distinguishes eligibility policies from approval policies."
    },
    "v1alpha1QueryAuditResponse": {
      "type": "object",
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1alpha1AuditEvent"
          }
        },
        "nextPageToken": {
          "type": "string"
        }
      },
      "description": "QueryAuditResponse wraps a page of audit events."
    },
    "v1alpha1RequestState": {
      "type": "string",
      "enum": [
        "REQUEST_STATE_UNSPECIFIED",
        "REQUEST_STATE_PENDING",
        "REQUEST_STATE_APPROVED",
        "REQUEST_STATE_REJECTED",
        "REQUEST_STATE_ACTIVE",
        "REQUEST_STATE_EXPIRED",
        "REQUEST_STATE_REVOKED"
      ],
      "default": "REQUEST_STATE_UNSPECIFIED",
      "description": "RequestState represents the lifecycle state of an elevation request."
    },
    "v1alpha1RevokeRequestResponse": {
      "type": "object",
      "properties": {
        "request": {
          "$ref": "#/definitions/v1alpha1ElevationRequest"
        }
      },
      "description": "RevokeRequestResponse wraps the updated request after revocation."
    }
  }
}
