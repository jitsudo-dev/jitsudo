# E2E test environment — copy to .env.e2e and fill in real values.
# .env.e2e is gitignored and must NEVER be committed.
#
# Usage:
#   cp test/e2e/.env.e2e.example test/e2e/.env.e2e
#   # edit .env.e2e with your values
#   source test/e2e/.env.e2e
#   E2E_ENABLED=true make test-e2e

# ── Core (required by all provider tests) ────────────────────────────────────
E2E_JITSUDOD_URL=https://your-jitsudod-instance:8443
E2E_JITSUDO_TOKEN=your-token-here
# Set E2E_INSECURE=true to skip TLS verification for local development.
# E2E_INSECURE=true

# ── AWS ──────────────────────────────────────────────────────────────────────
# IAM role that jitsudod will assume on the test principal's behalf.
E2E_AWS_ROLE_ARN=arn:aws:iam::123456789012:role/e2e-jitsudo-test
# Resource scope forwarded in the elevation request.
E2E_AWS_SCOPE=arn:aws:iam::123456789012:root
# Credentials that allow jitsudod to call sts:AssumeRole.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# ── Azure ─────────────────────────────────────────────────────────────────────
# Azure built-in or custom role name to assign (e.g. Reader, Contributor).
E2E_AZURE_ROLE=Reader
# Resource scope for the role assignment (typically a subscription or resource group).
E2E_AZURE_SCOPE=/subscriptions/00000000-0000-0000-0000-000000000000
# Service principal credentials for jitsudod.
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# ── GCP ───────────────────────────────────────────────────────────────────────
# IAM role to grant (e.g. roles/viewer, roles/editor).
E2E_GCP_ROLE=roles/viewer
# GCP project ID used as the resource scope.
E2E_GCP_PROJECT=my-gcp-project
# Path to a service account key file.  Omit to use Application Default Credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/jitsudod-sa.json

# ── Kubernetes ────────────────────────────────────────────────────────────────
# ClusterRole to bind for the test principal (e.g. view, edit).
E2E_K8S_CLUSTER_ROLE=view
# Namespace used as the resource scope for the RoleBinding.
E2E_K8S_NAMESPACE=default
# Path to kubeconfig.  Omit to use in-cluster config or the default ~/.kube/config.
# KUBECONFIG=/path/to/kubeconfig
